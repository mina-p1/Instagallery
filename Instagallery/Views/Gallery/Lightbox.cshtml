<!-- By Peter Mina -->

@model Instagallery.Models.PhotoModel

<div class="lightbox">
    <img src="@Model.Url" alt="@Model.Title" class="lightbox-photo" />
    <div class="photo-info">
        <h2>@Model.Title</h2>
        <p>@Model.Description</p>
        <p>Tags: @Model.Tags</p>
        <p>Uploaded on: @Model.UploadDate.ToShortDateString()</p>
    </div>
</div>

<style>
    .lightbox {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .lightbox-photo {
        max-width: 80%;
        max-height: 80vh;
    }
    .photo-info {
        text-align: center;
        margin-top: 15px;
    }
</style>